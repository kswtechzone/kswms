generator client {
  provider = "prisma-client-js"
}

generator client_root {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  isActive       Boolean  @default(true)
  enabledModules String[] @default(["DASHBOARD"]) // e.g., ["HOTEL_MANAGEMENT", "INVENTORY", "POS", "WEBSITE"]
  subscriptionPlan String @default("FREE") // FREE, GROWTH, ENTERPRISE
  country        String   @default("Nepal")
  currency       String   @default("NPR")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  users          User[]
  brands         Brand[]
  hotels         Hotel[]
  bookings       Booking[]
  websites       Website[]
  restaurants    Restaurant[]
  orders         Order[]
  inventory      InventoryItem[]
  staff          Staff[]
  guests         GuestProfile[]
  invoices       Invoice[]
  expenses       Expense[]
  parlorCategories ParlorCategory[]
  parlorServices ParlorService[]
  parlorBookings ServiceBooking[]
  coupons        Coupon[]
  couponRedemptions CouponRedemption[]
  
  // KSW centralized platform mappings
  memberships    OrganizationMembership[]
  platformCustomers CustomerOrganization[]
  platformResources SchedulableResource[]
  platformBookings  CentralBooking[]
}

model Brand {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  slug           String       @unique
  domain         String?      @unique
  themeColors    Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hotels         Hotel[]
  websites       Website[]
}

model User {
  id             String       @id @default(uuid())
  organizationId String
  email          String       @unique
  passwordHash   String
  name           String
  role           String       @default("USER") // SUPER_ADMIN, ADMIN, USER
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  staffProfile   Staff?
}

model Hotel {
  id             String       @id @default(uuid())
  organizationId String
  brandId        String
  name           String
  address        String
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brand          Brand        @relation(fields: [brandId], references: [id], onDelete: Cascade)
  rooms          Room[]
  restaurants    Restaurant[]
}

model Room {
  id                String   @id @default(uuid())
  hotelId           String
  roomNumber        String
  type              String   // Single, Double, Suite, Space
  dailyRate         Float
  capacity          Int      @default(2)
  status            String   @default("AVAILABLE") // AVAILABLE, OCCUPIED, MAINTENANCE
  isHourlyAvailable Boolean  @default(false)
  rate3h            Float?
  rate6h            Float?
  rate9h            Float?
  rate12h           Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt   DateTime?

  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  bookings    Booking[]
}

model Booking {
  id             String   @id @default(uuid())
  organizationId String
  roomId         String
  guestId        String?
  guestName      String
  guestEmail     String
  guestPhone     String?
  startTime      DateTime
  endTime        DateTime
  totalPrice     Float
  status         String   @default("PENDING") // PENDING, CONFIRMED, CHECKED_IN, COMPLETED, CANCELLED
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  room           Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  guest          GuestProfile? @relation(fields: [guestId], references: [id])
  orders         Order[]
  parlorBookings ServiceBooking[]
  invoices       Invoice[]
}

// --- Website Builder ---

model Website {
  id             String       @id @default(uuid())
  organizationId String
  brandId        String
  title          String
  description    String?
  subdomain      String?      @unique
  customDomain   String?      @unique
  status         String       @default("DRAFT") // DRAFT, PUBLISHED
  config         Json?        // Theme settings, header/footer config
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brand          Brand        @relation(fields: [brandId], references: [id], onDelete: Cascade)
  pages          CMSPage[]
}

model CMSPage {
  id             String       @id @default(uuid())
  websiteId      String
  title          String
  slug           String
  isHome         Boolean      @default(false)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  website        Website      @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  sections       CMSSection[]

  @@unique([websiteId, slug])
}

model CMSSection {
  id             String       @id @default(uuid())
  pageId         String
  type           String       // HERO, GALLERY, FEATURES, ROOMS, TESTIMONIALS
  content        Json?
  order          Int          @default(0)
  isActive       Boolean      @default(true)

  page           CMSPage      @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

// --- Restaurant POS ---

model Restaurant {
  id             String       @id @default(uuid())
  organizationId String
  hotelId        String?
  name           String
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hotel          Hotel?       @relation(fields: [hotelId], references: [id])
  menus          Menu[]
  tables         Table[]
  orders         Order[]
}

model Table {
  id             String       @id @default(uuid())
  restaurantId   String
  number         String
  capacity       Int
  status         String       @default("AVAILABLE") // AVAILABLE, OCCUPIED, RESERVED
  
  restaurant     Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders         Order[]
}

model Menu {
  id             String       @id @default(uuid())
  restaurantId   String
  name           String
  isActive       Boolean      @default(true)

  restaurant     Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categories     MenuCategory[]
}

model MenuCategory {
  id             String       @id @default(uuid())
  menuId         String
  name           String
  order          Int          @default(0)

  menu           Menu         @relation(fields: [menuId], references: [id], onDelete: Cascade)
  items          MenuItem[]
}

model MenuItem {
  id             String       @id @default(uuid())
  categoryId     String
  name           String
  description    String?
  price          Float
  image          String?
  isAvailable    Boolean      @default(true)

  category       MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model Order {
  id             String       @id @default(uuid())
  organizationId String
  restaurantId   String
  tableId        String?
  bookingId      String?      // Link to Room Booking for "Charge to Room"
  type           String       @default("DINE_IN") // DINE_IN, TAKEAWAY, DELIVERY
  status         String       @default("PENDING") // PENDING, KITCHEN, SERVED, COMPLETED, CANCELLED
  totalPrice     Float        @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  restaurant     Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table          Table?       @relation(fields: [tableId], references: [id])
  booking        Booking?     @relation(fields: [bookingId], references: [id])
  items          OrderItem[]
  invoices       Invoice[]
}

model OrderItem {
  id             String       @id @default(uuid())
  orderId        String
  menuItemId     String
  quantity       Int
  price          Float        // Snapshotted price at time of order
  notes          String?

  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// --- Inventory ---

model InventoryItem {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  sku            String?
  unit           String       // kg, pcs, ltr
  quantity       Float        @default(0)
  minQuantity    Float        @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions   InventoryTransaction[]
}

model InventoryTransaction {
  id             String       @id @default(uuid())
  itemId         String
  type           String       // IN, OUT, WASTE
  quantity       Float
  reference      String?      // Order ID or Purchase Order ID
  createdAt      DateTime     @default(now())

  item           InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

// --- HR & CRM ---

model Staff {
  id             String       @id @default(uuid())
  organizationId String
  userId         String       @unique
  designation    String
  salary         Float?
  joiningDate    DateTime
  status         String       @default("ACTIVE")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendance     Attendance[]
}

model Attendance {
  id             String       @id @default(uuid())
  staffId        String
  date           DateTime
  clockIn        DateTime?
  clockOut       DateTime?
  status         String       @default("PRESENT") // PRESENT, ABSENT, LEAVE

  staff          Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model GuestProfile {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  preferences    Json?
  loyaltyPoints  Int          @default(0)
  isKswProfile   Boolean      @default(true) // Unified customer KSW login profile representation
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookings       Booking[]
}

// --- Finance ---

model Invoice {
  id              String       @id @default(uuid())
  organizationId  String
  bookingId       String?      // Optional: Link to a specific room stay
  orderId         String?      // Optional: Link to a specific standalone order
  parlorBookingId String?      // Optional: Link to a parlor service booking
  invoiceNumber   String?      @unique
  totalAmount     Float
  tax             Float        @default(0)
  status          String       @default("UNPAID") // UNPAID, PAID, CANCELLED
  billingSnapshot Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking         Booking?     @relation(fields: [bookingId], references: [id])
  order           Order?       @relation(fields: [orderId], references: [id])
  parlorBooking   ServiceBooking? @relation(fields: [parlorBookingId], references: [id])
}

model Expense {
  id             String       @id @default(uuid())
  organizationId String
  category       String
  amount         Float
  description    String?
  date           DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id             String   @id @default(uuid())
  adminId        String
  adminName      String
  action         String   // e.g., "ASSIGN_MODULE", "REMOVE_MODULE", "CREATE_ORG"
  targetType     String   // e.g., "ORGANIZATION", "USER"
  targetId       String
  details        String?
  createdAt      DateTime @default(now())
}

// --- Parlor Management ---

model ParlorCategory {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  services       ParlorService[]
}

model ParlorService {
  id             String       @id @default(uuid())
  organizationId String
  categoryId     String
  name           String
  description    String?
  price          Float
  duration       Int          // in minutes
  image          String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       ParlorCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  bookingItems   BookingServiceItem[]
}

model ServiceBooking {
  id             String       @id @default(uuid())
  organizationId String
  bookingId      String?      // Optional: Link to a hotel stay
  guestName      String
  guestEmail     String?
  guestPhone     String?
  bookingTime    DateTime
  status         String       @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED, REFUNDED
  paymentMethod  String       @default("PAY_ON_VISIT") // PAY_NOW, PAY_ON_VISIT
  paymentStatus  String       @default("UNPAID") // PAID, UNPAID, REFUNDED
  totalPrice     Float
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roomStay       Booking?     @relation(fields: [bookingId], references: [id])
  services       BookingServiceItem[]
  invoices       Invoice[]
}

model BookingServiceItem {
  id             String       @id @default(uuid())
  bookingId      String
  serviceId      String
  priceAtBooking Float

  booking        ServiceBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service        ParlorService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model PlatformUser {
  id           String                   @id @default(uuid())
  username     String                   @unique
  email        String                   @unique
  phone        String?                  @unique
  passwordHash String
  isVerified   Boolean                  @default(false)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  memberships  OrganizationMembership[]
  customers    Customer[]               // Optional direct link to a customer profile

  @@index([email])
  @@index([phone])
}

model OrganizationMembership {
  id             String       @id @default(uuid())
  organizationId String
  platformUserId String
  role           String       @default("STAFF") // ADMIN, MANAGER, STAFF
  joinedAt       DateTime     @default(now())
  status         String       @default("ACTIVE") // PENDING, ACTIVE, SUSPENDED

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@unique([organizationId, platformUserId])
  @@index([organizationId])
  @@index([platformUserId])
}

model Customer {
  id             String                 @id @default(uuid())
  phone          String?                @unique
  email          String?                @unique
  fullName       String
  platformUserId String?                @unique // Nullable if the customer hasn't registered a KSW login account yet
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  platformUser   PlatformUser?          @relation(fields: [platformUserId], references: [id], onDelete: SetNull)
  organizations  CustomerOrganization[]

  @@index([email])
  @@index([phone])
}

model CustomerOrganization {
  id             String       @id @default(uuid())
  customerId     String
  organizationId String
  loyaltyPoints  Int          @default(0)
  notes          Json?        // Multi-structured logs (preferences, allergies, formulas)
  tags           String[]     @default([])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([customerId, organizationId])
  @@index([organizationId])
  @@index([customerId])
}

model SchedulableResource {
  id             String                 @id @default(uuid())
  organizationId String
  type           String                 // e.g., "HOTEL_ROOM", "SALON_CHAIR", "RESTAURANT_TABLE", "STAFF_STYLIST"
  name           String
  capacity       Int                    @default(1)
  isActive       Boolean                @default(true)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  bookings       BookingResourceLink[]

  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, type])
  @@index([organizationId, isActive])
}

model CentralBooking {
  id             String                 @id @default(uuid())
  organizationId String
  customerId     String                 // Central Global Customer Profile UUID
  type           String                 // e.g., "HOTEL", "SALON", "RESTAURANT", "EVENT"
  startTime      DateTime
  endTime        DateTime
  status         String                 @default("PENDING") // PENDING, RESERVED, CONFIRMED, IN_PROGRESS, COMPLETED, CANCELLED, NO_SHOW
  timezone       String                 @default("UTC")
  metadata       Json?                  // Dynamic workspace payloads (pricing audits, locks, guest specs)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  resources      BookingResourceLink[]

  // Domain-Specific Extension Mappings (1-to-1)
  hotelDetails      HotelBookingDetails?
  salonDetails      SalonBookingDetails?
  restaurantDetails RestaurantReservationDetails?

  @@index([organizationId, type])
  @@index([organizationId, status])
  @@index([startTime, endTime])
}

model BookingResourceLink {
  id             String              @id @default(uuid())
  bookingId      String
  resourceId     String

  booking        CentralBooking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  resource       SchedulableResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([bookingId, resourceId])
  @@index([bookingId])
  @@index([resourceId])
}

model HotelBookingDetails {
  bookingId  String         @id
  roomId     String
  guestCount Int            @default(1)
  nightCount Int

  booking    CentralBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  @@index([roomId])
}

model SalonBookingDetails {
  bookingId       String         @id
  staffId         String
  serviceIds      String[]       // References global ParlorService catalog
  durationMinutes Int

  booking         CentralBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  @@index([staffId])
}

model RestaurantReservationDetails {
  bookingId  String         @id
  tableId    String
  guestCount Int            @default(1)

  booking    CentralBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  @@index([tableId])
}

model Coupon {
  id             String             @id @default(uuid())
  organizationId String
  code           String             // e.g., "SAVE20"
  type           String             // "PERCENT" | "FIXED" | "FREE_ITEM"
  value          Float              // percentage discount or flat amount
  minOrderValue  Float              @default(0)
  maxDiscount    Float?             // Maximum cap for percentage discounts
  startDate      DateTime
  endDate        DateTime
  usageLimit     Int                @default(999999) // Global maximum redemptions
  perUserLimit   Int                @default(1)      // Maximum redemptions per user/customer
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scopes         CouponScope[]
  redemptions    CouponRedemption[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model CouponScope {
  id             String             @id @default(uuid())
  couponId       String
  moduleType     String             // "POS" | "PARLOR" | "HOTEL" | "ALL"
  entityType     String             // "ORDER" | "BOOKING" | "INVOICE"

  coupon         Coupon             @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
}

model CouponRedemption {
  id             String             @id @default(uuid())
  couponId       String
  userId         String?            // Central PlatformUser / Customer ID if present
  organizationId String
  referenceId    String             // target orderId, bookingId, or invoiceId
  discountApplied Float
  createdAt      DateTime           @default(now())

  coupon         Coupon             @relation(fields: [couponId], references: [id], onDelete: Cascade)
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([organizationId])
  @@index([referenceId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   // Maps to user id, email, or guest id
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

